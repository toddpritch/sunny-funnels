# GHL Configuration
GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=your_ghl_location_id_here
NEXT_PUBLIC_GHL_WEBHOOK_URL=https://api.gohighlevel.com/v1/contacts

# Geolocation (optional)
GEOLOCATION_API_KEY=your_geoip_api_key_here
# Get free key from: https://geoip-db.com

# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# Get from Google Analytics 4 property

# Offer Details
NEXT_PUBLIC_OFFER_TITLE=Your Offer Here
NEXT_PUBLIC_OFFER_PRICE=97
NEXT_PUBLIC_CURRENCY=USD
NEXT_PUBLIC_OFFER_CTA=Get Started

# Calendar
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/yourname

# Notifications (optional - Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Security
NEXT_PUBLIC_DASHBOARD_PASSWORD=change-this-to-your-password
